{
    "formatVersion": 1,
    "menu": {
        "global": {
            "label": "Einstellungen",
            "formFields": {
                "tenant_id": {
                    "type": "inputText",
                    "required": true,
                    "label": "Tenant-ID",
                    "options": {
                        "tooltip": "Deine Tenant-ID von widerruf.paketwo.de (im Dashboard unter 'Embed-Code')",
                        "defaultValue": ""
                    }
                },
                "embed_url": {
                    "type": "inputText",
                    "required": false,
                    "label": "Embed-Server URL",
                    "options": {
                        "tooltip": "URL der SaaS-Plattform",
                        "defaultValue": "https://widerruf.paketwo.de"
                    }
                },
                "embed_position": {
                    "type": "selectBox",
                    "required": false,
                    "label": "Position",
                    "options": {
                        "tooltip": "Wo die Widerrufsbelehrung erscheinen soll",
                        "defaultValue": "footer",
                        "selectBoxValues": [
                            {"value": "footer", "caption": "Footer (inline)"},
                            {"value": "fixed_bottom_right", "caption": "Sticky Button (unten rechts)"}
                        ]
                    }
                }
            }
        }
    }
}
