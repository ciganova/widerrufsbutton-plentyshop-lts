{# EmbedScript.twig — ShopBuilder Widget
   Rendert die DSGVO-konforme Widerrufsbelehrung via SaaS-Embed.
   
   Konfiguration (im ShopBuilder):
   - tenant_id: Deine Tenant-ID von widerruf.paketwo.de
#}

{% set tid = tenant_id | default('') %}

{% if tid is not empty %}
    {% if not is_preview %}
    <script src="https://widerruf.paketwo.de/e/{{ tid }}.js" defer></script>
    {% endif %}
    <div id="widerruf-root-{{ tid }}" class="widerruf-root" style="min-height:60px">
        <a href="https://widerruf.paketwo.de/e/{{ tid }}/config.json" 
           target="_blank" rel="nofollow"
           style="display:inline-block;padding:12px 28px;background:#cd0001;color:#fff;border-radius:6px;text-decoration:none;font-family:sans-serif;font-size:15px;font-weight:600">
            📄 Widerrufsformular öffnen
        </a>
    </div>
    <noscript>
        <p style="text-align:center;padding:1rem;">
            <a href="https://widerruf.paketwo.de/e/{{ tid }}/config.json"
               rel="nofollow" target="_blank">
                Widerrufsbelehrung & Muster-Widerrufsformular
            </a>
        </p>
    </noscript>
{% else %}
    <div style="padding:1rem;text-align:center;background:#f5f5f5;border:2px dashed #ccc;border-radius:6px;color:#666;font-family:sans-serif;font-size:14px">
        ⚙️ Widerrufsbelehrung — Tenant-ID in den Widget-Einstellungen hinterlegen
    </div>
{% endif %}
