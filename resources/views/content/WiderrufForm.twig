{# WiderrufForm.twig — Step 1: Withdrawal Form #}
{#
  § 356a BGB compliant withdrawal form.
  - Accessible without login
  - Only asks: name, order ID, contact email
  - Reason field is optional (must NOT be required!)
  - Clear "Vertrag widerrufen" CTA → goes to confirmation page
#}
{% extends "Ceres::PageDesign.PageDesign" %}

{% set shopName = shopName|default('Unser Online-Shop') %}

{% block PageBody %}
<div class="widerruf-container" id="widerruf-app">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9">

                {# Header #}
                <div class="text-center mb-4">
                    <div class="widerruf-icon mb-3">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 12h18M3 6h18M3 18h12"/>
                            <polyline points="15 15 12 18 9 15"/>
                        </svg>
                    </div>
                    <h1 class="widerruf-title">Vertrag widerrufen</h1>
                    <p class="widerruf-subtitle text-muted">
                        Hier können Sie Ihren Vertrag einfach und direkt online widerrufen.
                        Kein Formular-Download, kein Ausdrucken – nur dieses Formular ausfüllen.
                    </p>
                </div>

                {# Error Messages #}
                {% if errors is not empty %}
                <div class="alert alert-danger" role="alert">
                    <strong>Bitte korrigieren Sie folgende Punkte:</strong>
                    <ul class="mb-0 mt-2">
                        {% for error in errors %}
                            <li>{{ error }}</li>
                        {% endfor %}
                    </ul>
                </div>
                {% endif %}

                {# Info: Required fields #}
                <div class="alert alert-info widerruf-info" role="alert">
                    <small>
                        <strong>Hinweis:</strong> Sie können Ihren Widerruf ohne Angabe von Gründen erklären.
                        Die mit <span class="text-danger">*</span> markierten Felder sind Pflichtangaben gemäß § 356a BGB.
                    </small>
                </div>

                {# Form #}
                <form method="POST" action="{{ formAction }}" id="widerruf-form" novalidate>
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

                    {# Name #}
                    <div class="mb-3">
                        <label for="widerruf-name" class="form-label">
                            Name <span class="text-danger">*</span>
                        </label>
                        <input
                            type="text"
                            class="form-control{% if errors is not empty and oldInput.name is empty %} is-invalid{% endif %}"
                            id="widerruf-name"
                            name="name"
                            value="{{ oldInput.name|default('')|escape('html_attr') }}"
                            placeholder="Vor- und Nachname"
                            required
                            autocomplete="name"
                            minlength="2"
                        >
                        <div class="form-text">Geben Sie bitte Ihren vollständigen Namen an.</div>
                    </div>

                    {# Order ID #}
                    <div class="mb-3">
                        <label for="widerruf-order-id" class="form-label">
                            Bestellnummer <span class="text-danger">*</span>
                        </label>
                        <input
                            type="text"
                            class="form-control{% if errors is not empty and oldInput.order_id is empty %} is-invalid{% endif %}"
                            id="widerruf-order-id"
                            name="order_id"
                            value="{{ oldInput.order_id|default('')|escape('html_attr') }}"
                            placeholder="z.B. 12345"
                            required
                            autocomplete="off"
                        >
                        <div class="form-text">
                            Ihre Bestellnummer finden Sie in der Bestellbestätigung per E-Mail.
                        </div>
                        <div id="order-lookup-result" class="mt-1" style="display:none;"></div>
                    </div>

                    {# Email #}
                    <div class="mb-3">
                        <label for="widerruf-email" class="form-label">
                            E-Mail <span class="text-danger">*</span>
                        </label>
                        <input
                            type="email"
                            class="form-control{% if errors is not empty and oldInput.email is empty %} is-invalid{% endif %}"
                            id="widerruf-email"
                            name="email"
                            value="{{ oldInput.email|default('')|escape('html_attr') }}"
                            placeholder="ihre@email.de"
                            required
                            autocomplete="email"
                        >
                        <div class="form-text">
                            An diese Adresse senden wir die Eingangsbestätigung Ihres Widerrufs.
                        </div>
                    </div>

                    {# Reason (OPTIONAL — must not be required!) #}
                    <div class="mb-4">
                        <label for="widerruf-reason" class="form-label">
                            Grund <small class="text-muted">(freiwillig)</small>
                        </label>
                        <textarea
                            class="form-control"
                            id="widerruf-reason"
                            name="reason"
                            rows="3"
                            placeholder="Sie müssen keinen Grund angeben. Falls Sie uns dennoch mitteilen möchten, warum Sie widerrufen, können Sie das hier tun."
                        >{{ oldInput.reason|default('')|escape('html') }}</textarea>
                        <div class="form-text">
                            Die Angabe eines Grundes ist freiwillig und dient nur Ihrer Information.
                            Der Widerruf ist auch ohne Begründung wirksam.
                        </div>
                    </div>

                    {# Submit → Step 2 #}
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg widerruf-btn">
                            Vertrag widerrufen
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ms-2">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                        </button>
                    </div>

                    <p class="text-center mt-3 mb-0">
                        <small class="text-muted">
                            Mit Klick auf „Vertrag widerrufen" gelangen Sie zur Bestätigungsseite.
                            Der Widerruf wird erst nach Ihrer endgültigen Bestätigung übermittelt.
                        </small>
                    </p>
                </form>

                {# Alternative contact #}
                <hr class="my-4">
                <div class="widerruf-alternative">
                    <h5>Alternative Widerrufswege</h5>
                    <p class="text-muted small">
                        Sie können Ihren Widerruf auch weiterhin per E-Mail, Brief oder mit dem
                        <a href="/widerrufsformular" target="_blank" rel="noopener">Muster-Widerrufsformular</a>
                        erklären. Der Widerrufsbutton ergänzt diese Möglichkeiten, ersetzt sie aber nicht.
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}
