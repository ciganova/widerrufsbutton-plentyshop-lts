{# WiderrufSuccess.twig — Step 3: Success Page After Submission #}
{#
  Shown after the withdrawal has been submitted.
  Confirms receipt and explains next steps.
#}
{% extends "Ceres::PageDesign.PageDesign" %}

{% set shopName = shopName|default('Unser Online-Shop') %}

{% block PageBody %}
<div class="widerruf-container" id="widerruf-success">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9 text-center">

                {# Success Icon #}
                <div class="widerruf-success-icon mb-4">
                    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#198754" stroke-width="1.5">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="8 13 11 16 16 8"/>
                    </svg>
                </div>

                {# Header #}
                <h1 class="widerruf-title mb-3">Ihr Widerruf wurde übermittelt</h1>
                <p class="widerruf-subtitle text-muted mb-4">
                    Vielen Dank, {{ name|escape }}. Ihre Widerrufserklärung ist bei uns eingegangen.
                </p>

                {# Confirmation Details Card #}
                <div class="card widerruf-success-card text-start mb-4">
                    <div class="card-header bg-success text-white">
                        <strong>Eingangsbestätigung</strong>
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless mb-0">
                            <tr>
                                <td class="text-muted" style="width: 160px;">Bestellnummer</td>
                                <td><strong>{{ orderId|escape }}</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Eingegangen am</td>
                                <td>{{ submittedAt }} Uhr</td>
                            </tr>
                            <tr>
                                <td class="text-muted">E-Mail-Bestätigung an</td>
                                <td>{{ email|escape }}</td>
                            </tr>
                            {% if returnId %}
                            <tr>
                                <td class="text-muted">Vorgangsnummer</td>
                                <td>{{ returnId }}</td>
                            </tr>
                            {% endif %}
                        </table>
                    </div>
                </div>

                {# Next Steps #}
                <div class="card widerruf-next-steps text-start mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Wie geht es weiter?</h5>
                        <ol class="mb-0 small">
                            <li class="mb-2">
                                <strong>Eingangsbestätigung:</strong> Sie erhalten in Kürze eine E-Mail an
                                <strong>{{ email|escape }}</strong> mit der Bestätigung des Eingangs
                                Ihrer Widerrufserklärung (Datum und Uhrzeit).
                            </li>
                            <li class="mb-2">
                                <strong>Prüfung:</strong> Wir prüfen Ihren Widerruf und senden Ihnen
                                eine separate E-Mail mit Informationen zum weiteren Ablauf
                                und zur Rücksendung der Ware.
                            </li>
                            <li class="mb-2">
                                <strong>Rückerstattung:</strong> Nach Eingang der Ware bei uns oder
                                nachdem Sie den Versand nachgewiesen haben, erstatten wir Ihnen
                                den Kaufpreis auf demselben Zahlungsweg zurück, den Sie bei der
                                Bestellung verwendet haben.
                            </li>
                        </ol>
                    </div>
                </div>

                {# CTA: Back to Shop #}
                <a href="/" class="btn btn-outline-primary btn-lg">
                    Zurück zum Shop
                </a>

                {# Note #}
                <p class="text-muted small mt-4">
                    Falls Sie Fragen haben, antworten Sie einfach auf unsere E-Mail oder
                    kontaktieren Sie uns über unser <a href="/contact">Kontaktformular</a>.
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
