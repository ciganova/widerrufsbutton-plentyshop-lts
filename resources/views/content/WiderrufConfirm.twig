{# WiderrufConfirm.twig — Step 2: Confirmation Page #}
{#
  § 356a BGB: Two-step process — this is the confirmation page
  where the user must explicitly confirm the withdrawal.
  Button says "Widerruf bestätigen" as required by law.
#}
{% extends "Ceres::PageDesign.PageDesign" %}

{% set shopName = shopName|default('Unser Online-Shop') %}

{% block PageBody %}
<div class="widerruf-container" id="widerruf-confirm">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9">

                {# Step Indicator #}
                <div class="widerruf-steps text-center mb-4">
                    <div class="d-flex justify-content-center align-items-center gap-2">
                        <span class="badge bg-secondary rounded-pill px-3 py-2">1. Daten eingeben</span>
                        <span class="text-muted">→</span>
                        <span class="badge bg-danger rounded-pill px-3 py-2">2. Bestätigen</span>
                    </div>
                </div>

                {# Header #}
                <div class="text-center mb-4">
                    <h1 class="widerruf-title">Widerruf bestätigen</h1>
                    <p class="widerruf-subtitle text-muted">
                        Bitte überprüfen Sie Ihre Angaben und bestätigen Sie den Widerruf.
                    </p>
                </div>

                {# Summary Card #}
                <div class="card widerruf-summary-card mb-4">
                    <div class="card-header bg-light">
                        <strong>Zusammenfassung Ihres Widerrufs</strong>
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless mb-0">
                            <tr>
                                <td class="text-muted" style="width: 150px;">Name</td>
                                <td><strong>{{ name|escape }}</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Bestellnummer</td>
                                <td><strong>{{ orderId|escape }}</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">E-Mail</td>
                                <td>{{ email|escape }}</td>
                            </tr>
                            {% if orderDate %}
                            <tr>
                                <td class="text-muted">Bestelldatum</td>
                                <td>{{ orderDate|date('d.m.Y') }}</td>
                            </tr>
                            {% endif %}
                        </table>

                        {# Order Items (if available) #}
                        {% if orderItems is not empty %}
                        <hr>
                        <p class="text-muted mb-2"><strong>Betroffene Artikel:</strong></p>
                        <ul class="list-unstyled mb-0">
                            {% for item in orderItems %}
                                <li class="text-muted small">
                                    {{ item.quantity }}× {{ item.name|escape }}
                                </li>
                            {% endfor %}
                        </ul>
                        {% endif %}

                        {% if reason is not empty %}
                        <hr>
                        <p class="text-muted mb-1"><strong>Ihre Nachricht:</strong></p>
                        <p class="mb-0 fst-italic">{{ reason|escape|nl2br }}</p>
                        {% endif %}
                    </div>
                </div>

                {# Confirmation Button #}
                <form method="POST" action="{{ formAction }}" id="widerruf-confirm-form">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="name" value="{{ name|escape('html_attr') }}">
                    <input type="hidden" name="order_id" value="{{ orderId|escape('html_attr') }}">
                    <input type="hidden" name="email" value="{{ email|escape('html_attr') }}">
                    <input type="hidden" name="reason" value="{{ reason|escape('html_attr') }}">

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg widerruf-confirm-btn" id="confirm-btn">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            Widerruf bestätigen
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <a href="/widerruf" class="text-muted small">
                            ← Zurück und Angaben ändern
                        </a>
                    </div>
                </form>

                {# Legal Notice #}
                <div class="alert alert-warning mt-4" role="alert">
                    <small>
                        <strong>Wichtiger Hinweis:</strong> Mit Klick auf „Widerruf bestätigen"
                        erklären Sie verbindlich den Widerruf Ihres Vertrags. Sie erhalten
                        unverzüglich eine Eingangsbestätigung per E-Mail mit Datum und Uhrzeit.
                        Die Wirksamkeit Ihres Widerrufs wird anschließend von uns geprüft.
                    </small>
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}
